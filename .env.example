# ============================================================
# 몽글픽 클라이언트 환경변수 템플릿 (.env.example)
# ============================================================
# 이 파일을 복사하여 .env로 만든 뒤 실제 값을 입력하세요:
#   cp .env.example .env
# Vite 환경변수는 VITE_ 접두사 필수
# ============================================================

# ── API 기본 URL ──
# 개발 환경: Vite 프록시 사용 (빈 문자열)
# 프로덕션: 실제 도메인 입력 (예: https://api.monglepick.com)
VITE_API_BASE_URL=

# ── Spring Boot 백엔드 ──
VITE_BACKEND_URL=http://localhost:8080

# ── AI Agent ──
VITE_AGENT_URL=http://localhost:8000

# ── 추천/검색/온보딩 시스템 ──
VITE_RECOMMEND_URL=http://localhost:8001

# ── OAuth 클라이언트 ID ──
# 각 제공자의 개발자 콘솔에서 발급받은 클라이언트 ID를 입력하세요
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_KAKAO_CLIENT_ID=your-kakao-client-id
VITE_NAVER_CLIENT_ID=your-naver-client-id

# ── OAuth 리다이렉트 URI ──
VITE_OAUTH_REDIRECT_BASE=http://localhost:5173

# ── Toss Payments ──
# Toss 개발자센터에서 발급받은 클라이언트 키를 입력하세요
VITE_TOSS_CLIENT_KEY=your-toss-client-key
